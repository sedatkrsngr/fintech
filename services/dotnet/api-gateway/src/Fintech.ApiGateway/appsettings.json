{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Gateway": {
    "ServiceName": "api-gateway",
    "BasePath": "/"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-health-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/health/identity"
        },
        "Transforms": [
          {
            "PathSet": "/health"
          }
        ]
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "wallet-health-route": {
        "ClusterId": "wallet-cluster",
        "Match": {
          "Path": "/health/wallet"
        },
        "Transforms": [
          {
            "PathSet": "/health"
          }
        ]
      },
      "wallet-route": {
        "ClusterId": "wallet-cluster",
        "Match": {
          "Path": "/api/wallet/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "ledger-health-route": {
        "ClusterId": "ledger-cluster",
        "Match": {
          "Path": "/health/ledger"
        },
        "Transforms": [
          {
            "PathSet": "/health"
          }
        ]
      },
      "ledger-route": {
        "ClusterId": "ledger-cluster",
        "Match": {
          "Path": "/api/ledger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "transfer-health-route": {
        "ClusterId": "transfer-cluster",
        "Match": {
          "Path": "/health/transfer"
        },
        "Transforms": [
          {
            "PathSet": "/health"
          }
        ]
      },
      "transfer-route": {
        "ClusterId": "transfer-cluster",
        "Match": {
          "Path": "/api/transfer/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "notification-health-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/health/notification"
        },
        "Transforms": [
          {
            "PathSet": "/health"
          }
        ]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notification/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "notification-hub-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/hubs/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/hubs/notifications/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "wallet-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "ledger-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "transfer-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5004/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5005/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
